rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidDataCollection(name) {
      // Note: 'completions' and 'custom_completions' are intentionally
      // excluded here — they now live in dedicated shard subcollections
      // (users/{uid}/completions/{YYYY-MM}), not in the flat /data/ path.
      return name in [
        'habits', 'subtasks', 'subtask_completions',
        'custom_habits', 'custom_subtasks', 'custom_subtask_completions',
        'daily_tasks', 'settings', 'stopwatch_history', 'notes', 'goals',
        'study_sessions', 'productivity_sessions'
      ];
    }

    function isValidSize() {
      return request.resource.size < 500000;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);

      match /data/{collectionName} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && isValidDataCollection(collectionName)
          && isValidSize();
        allow delete: if isOwner(userId);
      }

      match /completions/{monthKey} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidSize();
        allow delete: if isOwner(userId);
      }

      match /custom_completions/{monthKey} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidSize();
        allow delete: if isOwner(userId);
      }

      match /stopwatch/{monthKey} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidSize();
        allow delete: if isOwner(userId);
      }

      match /daily_tasks/{monthKey} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidSize();
        allow delete: if isOwner(userId);
      }


      match /devices/{deviceId} {
        allow read, write, delete: if isOwner(userId);
      }

      // Rate-limiting metadata written by the validateImport Cloud Function
      // (via the Admin SDK). These rules protect client-side access.
      match /meta/{docId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
